{
  "name": "tavi",
  "version": "0.9.19",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "corepack pnpm -r --workspace-concurrency 1 --filter \"./apps/*\" --filter \"./packages/*\" --if-present build",
    "dev": "corepack pnpm -r --parallel --filter \"./apps/*\" --filter \"./packages/*\" --if-present dev",
    "lint": "corepack pnpm -r --workspace-concurrency 1 --filter \"./apps/*\" --filter \"./packages/*\" --if-present lint",
    "test": "corepack pnpm -r --workspace-concurrency 1 --filter \"./apps/*\" --filter \"./packages/*\" --if-present test",
    "typecheck": "corepack pnpm -r --workspace-concurrency 1 --filter \"./apps/*\" --filter \"./packages/*\" --if-present typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3"
  }
}
