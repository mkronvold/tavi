# Copy this file to a local path such as infra/docker/compose-prod.env and pass
# it to docker compose with:
#   docker compose --env-file infra/docker/compose-prod.env -f infra/docker/compose-prod.yaml up -d

TAVI_TAG=latest

# Published-image runtime ports on the Docker host.
TAVI_WEB_HOST_PORT=5173
TAVI_API_HOST_PORT=4000
TAVI_WORKER_HOST_PORT=4100
TAVI_POSTGRES_HOST_PORT=5432

# Browser-facing URLs for the web container and API CORS policy.
TAVI_HOME_URL=http://localhost:5173
TAVI_API_BASE_URL=http://localhost:4000/api
TAVI_CORS_ORIGIN=http://localhost:5173

# Required secret for API sessions.
TAVI_COOKIE_SECRET=replace-with-a-long-random-secret

# Shared backup path inside the API and worker containers.
TAVI_BACKUP_DIRECTORY=/var/tavi/backups

# Internal Postgres service settings used by compose-prod by default.
POSTGRES_DB=tavi
POSTGRES_USER=tavi
POSTGRES_PASSWORD=replace-me

# Optional override if API and worker should connect somewhere other than the
# bundled postgres service above. The compose postgres container will still
# start unless you also edit compose-prod.yaml.
# TAVI_DATABASE_URL=postgresql://tavi:replace-me@postgres:5432/tavi?schema=public

# Optional SMTP settings for outbound email.
SMTP_URL=smtp://10.120.64.99:25
SMTP_FROM=noreply@tavi.local
SMTP_USER=
SMTP_PASS=
