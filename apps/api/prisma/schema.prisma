generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  editor
  viewer
}

enum Priority {
  low
  medium
  high
}

enum TaskStatus {
  not_started
  in_progress
  demo
  review
  done
  blocked
  on_hold
  canceled
}

enum PersonalTodoStatus {
  todo
  done
}

enum ProjectStatus {
  not_started
  in_progress
  demo
  review
  done
  blocked
  on_hold
  canceled
}

enum NotificationKind {
  daily_non_admin_digest
  hourly_non_admin_digest
  task_assigned
  task_unassigned
  task_updated
  task_due_date_added
  task_due_date_changed
  task_blocked
  task_unblocked
  task_on_hold
  task_resumed
  task_reopened
  task_completed
  task_moved
  project_updated
  project_owner_assigned
  project_owner_changed
  project_owner_removed
  project_blocked
  project_on_hold
  project_resumed
  task_due_7_days
  task_due_3_days
  task_due_tomorrow
  task_due_today
  task_overdue
  personal_todo_due_7_days
  personal_todo_due_3_days
  personal_todo_due_tomorrow
  personal_todo_due_today
  personal_todo_overdue
  daily_task_summary
  daily_project_summary
}

enum NotificationStatus {
  queued
  processing
  sent
  skipped
  failed
}

enum ImportJobStatus {
  queued_parse
  parsing
  awaiting_review
  queued_commit
  committing
  completed
  failed
}

enum ImportRowOutcome {
  pending
  created
  updated
  skipped
  failed
}

enum ImportOverlapAction {
  update
  add
  ignore
}

enum AuditEntityType {
  auth
  project
  task
  saved_view
}

enum AuditLogRetentionWindow {
  one_day
  one_week
  one_month
  three_months
  six_months
  one_year
}

enum PersonalTodoRetentionPolicy {
  never
  one_month
  three_months
  six_months
  twelve_months
  delete_when_done
}

model User {
  id                           String                      @id @default(cuid())
  email                        String                      @unique
  name                         String
  passwordHash                 String
  passwordResetOtpHash         String?
  passwordResetOtpExpiresAt    DateTime?
  dailyDigestEnabled           Boolean                     @default(false)
  dailyDigestTime              String                      @default("11:00")
  personalTodoRetention        PersonalTodoRetentionPolicy @default(never)
  personalTodoRemindersEnabled Boolean                     @default(true)
  userConfigJson               String?
  roleAssignment               RoleAssignment?
  ownedProjects                Project[]                   @relation("ProjectOwner")
  assignedTasks                Task[]                      @relation("TaskAssignee")
  personalTodos                PersonalTodo[]
  createdImports               ImportJob[]                 @relation("ImportCreator")
  savedViews                   SavedView[]
  auditEvents                  AuditEvent[]                @relation("AuditActor")
  notifications                NotificationEvent[]         @relation("NotificationRecipient")
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt
}

model RoleAssignment {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      Role
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                  String         @id @default(cuid())
  title               String
  notes               String?
  references          String?
  ownerUserId         String?
  owner               User?          @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  dueDate             DateTime?
  priority            Priority       @default(medium)
  derivedStatus       ProjectStatus  @default(not_started)
  displayStatus       ProjectStatus  @default(not_started)
  manualStatus        ProjectStatus?
  taskTotalCount      Int            @default(0)
  taskTodoCount       Int            @default(0)
  taskInProgressCount Int            @default(0)
  taskBlockedCount    Int            @default(0)
  taskOnHoldCount     Int            @default(0)
  taskDoneCount       Int            @default(0)
  taskCanceledCount   Int            @default(0)
  taskOverdueCount    Int            @default(0)
  sourceSystem        String?
  sourceExternalId    String?
  archivedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  tasks               Task[]

  @@unique([sourceSystem, sourceExternalId])
  @@index([ownerUserId])
  @@index([displayStatus])
}

model Task {
  id               String     @id @default(cuid())
  projectId        String
  project          Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  notes            String?
  assigneeUserId   String?
  assignee         User?      @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  dueDate          DateTime?
  priority         Priority   @default(medium)
  status           TaskStatus @default(not_started)
  sortOrder        Int        @default(0)
  sourceSystem     String?
  sourceExternalId String?
  archivedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  completedAt      DateTime?

  @@unique([sourceSystem, sourceExternalId])
  @@index([projectId, sortOrder])
  @@index([assigneeUserId])
  @@index([status])
}

model PersonalTodo {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  notes       String?
  dueDate     DateTime?
  status      PersonalTodoStatus @default(todo)
  sortOrder   Int                @default(0)
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId, sortOrder])
  @@index([userId, dueDate])
  @@index([userId, status])
}

model SavedView {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  groupBy      String         @default("owner")
  search       String         @default("")
  statusFilter ProjectStatus?
  filtersJson  Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
}

model ImportJob {
  id                  String          @id @default(cuid())
  createdByUserId     String
  createdBy           User            @relation("ImportCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  sourceSystem        String          @default("loop")
  fileName            String
  status              ImportJobStatus @default(queued_parse)
  sourceContent       String
  headers             Json?
  mapping             Json?
  suggestedMapping    Json?
  totalRowCount       Int             @default(0)
  createdRowCount     Int             @default(0)
  updatedRowCount     Int             @default(0)
  skippedRowCount     Int             @default(0)
  failedRowCount      Int             @default(0)
  createdProjectCount Int             @default(0)
  updatedProjectCount Int             @default(0)
  createdTaskCount    Int             @default(0)
  updatedTaskCount    Int             @default(0)
  lastError           String?
  completedAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  rows                ImportRow[]

  @@index([status, createdAt])
  @@index([createdByUserId, createdAt])
}

model ImportRow {
  id                   String              @id @default(cuid())
  importId             String
  importJob            ImportJob           @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowNumber            Int
  rawData              Json
  projectOverlapAction ImportOverlapAction @default(update)
  taskOverlapAction    ImportOverlapAction @default(update)
  rowOutcome           ImportRowOutcome    @default(pending)
  projectOutcome       ImportRowOutcome    @default(pending)
  taskOutcome          ImportRowOutcome    @default(pending)
  projectId            String?
  taskId               String?
  message              String?
  validationErrors     Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@unique([importId, rowNumber])
  @@index([importId, rowOutcome])
}

model AuditEvent {
  id          String          @id @default(cuid())
  actorUserId String?
  actor       User?           @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail  String
  actorName   String
  actorRole   Role?
  entityType  AuditEntityType
  entityId    String
  action      String
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([entityType, entityId])
  @@index([entityType, createdAt])
  @@index([action, createdAt])
  @@index([actorUserId])
}

model AuditLogRetention {
  id        String                  @id @default("global")
  olderThan AuditLogRetentionWindow
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model EmailSettings {
  id                 String   @id @default("global")
  enabled            Boolean  @default(true)
  dragHandlesEnabled Boolean  @default(true)
  guestAccessEnabled Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BackupSettings {
  id                 String    @id @default("global")
  enabled            Boolean   @default(false)
  scheduleTime       String    @default("02:00")
  lastScheduledRunAt DateTime?
  lastSuccessAt      DateTime?
  lastFailureAt      DateTime?
  lastError          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model RetentionSettings {
  id                    String   @id @default("global")
  backupRetention       String   @default("six_months")
  loginRetention        String   @default("twelve_months")
  changeRetention       String   @default("twelve_months")
  notificationRetention String   @default("one_month")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model NotificationEvent {
  id               String                        @id @default(cuid())
  recipientUserId  String?
  recipient        User?                         @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  kind             NotificationKind
  dedupeKey        String?                       @unique
  payload          Json
  status           NotificationStatus            @default(queued)
  attemptCount     Int                           @default(0)
  lastError        String?
  nextAttemptAt    DateTime                      @default(now())
  sentAt           DateTime?
  skippedAt        DateTime?
  failedAt         DateTime?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  deliveryAttempts NotificationDeliveryAttempt[]

  @@index([status, nextAttemptAt, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([kind, createdAt])
}

model NotificationDeliveryAttempt {
  id             String             @id @default(cuid())
  notificationId String
  notification   NotificationEvent  @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  status         NotificationStatus
  error          String?
  createdAt      DateTime           @default(now())

  @@index([notificationId, createdAt])
}
